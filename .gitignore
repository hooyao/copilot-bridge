# Build output. Note: [Dd]ebug/ and [Rr]elease/ would also match the source
# folder src/CopilotBridge.Cli/Debug/ (which holds DebugCommand.cs) — leave
# the bare patterns out and rely on bin/ + obj/ to cover MSBuild output.
[Bb]in/
[Oo]bj/
x64/
x86/
[Aa][Rr][Mm]64/

# AOT / publish output
publish/
publish-aot/
artifacts/
*.[Pp]ublish.xml
*.pubxml
*.publishproj

# IDE
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets

# Logs / coverage / test results
*.log
*.tlog
*.binlog
[Tt]est[Rr]esult*/
coverage*.json
coverage*.xml
*.coverage

# OS
Thumbs.db
.DS_Store

# Project-specific
appsettings.dev.jsonc
appsettings.local.jsonc
appsettings.dev.json
appsettings.local.json
# The read-only copilot-api clone at the repo root (a separate checkout; never
# commit it). Anchored with a leading slash so it matches only the root dir, not
# a `references/` subfolder elsewhere (e.g. a skill's own references/).
/references/
.claude/*
# ...except this repo's own version-controlled skills, so every clone (and every
# agent working here) gets them. We do NOT blanket-track .claude/skills/ because
# other Claude Code plugins install their skills there too (openspec, etc.) —
# those aren't ours to commit. Un-ignore the skills dir so git can descend into
# it, ignore everything under it, then re-include only the repo-owned skills by
# name. (git can't re-include a path whose parent is ignored, hence the layering:
# .claude/* → !.claude/skills/ → .claude/skills/* → !.claude/skills/<ours>/)
!.claude/skills/
.claude/skills/*
!.claude/skills/copilot-model-sync/

# Local-only: MCP server config + Claude Code session-handoff dumps (never commit)
.mcp.json
*-this-session-is-being-continued-*.txt

# Claude Code's own npm install lands at the repo root when the user runs
# `claude` here — those artifacts have nothing to do with this .NET project.
node_modules/
package.json
package-lock.json

# Encrypted GitHub token (DPAPI-protected, but never commit it anyway)
github_token.dat

# Bridge logs and harness scratch output. log/ = always-on text log;
# request-traces/ = opt-in per-request JSON audit (Tracing.Enabled).
logs/
log/
request-traces/
tests/harness/last-stdout.txt
tests/harness/last-stderr.txt

# docs/scratch/ is throwaway working material — capture scripts, raw session
# dumps with real ids/git metadata, de-identification helpers. The committed
# artifacts they produce live elsewhere (de-identified fixtures under
# tests/.../Fixtures/, design docs under docs/). Never commit scratch itself.
# See docs/codex-protocol-research.md §3.4 + tests/.../Fixtures/README.md.
docs/scratch/
